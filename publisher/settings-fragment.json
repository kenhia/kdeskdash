{
  "//": "kdeskdash claude-feed publisher — merge into user-level ~/.claude/settings.json.",
  "//path": "Use the machine's absolute path to claude-pub.sh; forward slashes work in Git Bash on Windows (e.g. C:/Users/kenhi/.claude/kdeskdash-pub/claude-pub.sh).",
  "statusLine": {
    "type": "command",
    "command": "/home/ken/.claude/kdeskdash-pub/claude-pub.sh statusline"
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "/home/ken/.claude/kdeskdash-pub/claude-pub.sh hook", "async": true, "timeout": 5 } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "/home/ken/.claude/kdeskdash-pub/claude-pub.sh hook", "async": true, "timeout": 5 } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "/home/ken/.claude/kdeskdash-pub/claude-pub.sh hook", "async": true, "timeout": 5 } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "/home/ken/.claude/kdeskdash-pub/claude-pub.sh hook", "async": false, "timeout": 5 } ] }
    ]
  }
}
