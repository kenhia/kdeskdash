# kdeskdash environment — install to /etc/kdeskdash/kdeskdash.env (mode 0600).
# All values are optional; the defaults shown match the built-in fallbacks.

# Display: DRM device (card1 = vc4 GPU on the Pi 5).
KDESKDASH_DRM_DEV=/dev/dri/card1

# Touch: evdev device. Prefer the stable by-id symlink — event node numbers
# (event0, event1, ...) can change across replug/reboot.
KDESKDASH_TOUCH_DEV=/dev/input/by-id/usb-ILITEK_ILITEK-TOUCH-event-if00

# Redis (optional — the dashboard runs fully by touch without it).
KDESKDASH_REDIS_HOST=127.0.0.1
KDESKDASH_REDIS_PORT=6379
# Uncomment and set if your Redis requires a password (AUTH).
#REDISCLI_AUTH=changeme
