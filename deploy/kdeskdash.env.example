# kdeskdash environment — install to /etc/kdeskdash/kdeskdash.env (mode 0600).
# All values are optional; the defaults shown match the built-in fallbacks.

# Display: DRM device (card1 = vc4 GPU on the Pi 5).
KDESKDASH_DRM_DEV=/dev/dri/card1

# Display: flip the whole UI 180° (the panel mounts inverted in the case).
# Accepts 1/true/yes/on; anything else is off. Rotates render and touch together.
#KDESKDASH_ROTATE_180=1

# Touch: evdev device. Prefer the stable by-id symlink — event node numbers
# (event0, event1, ...) can change across replug/reboot.
KDESKDASH_TOUCH_DEV=/dev/input/by-id/usb-ILITEK_ILITEK-TOUCH-event-if00

# Control Redis (optional — the dashboard runs fully by touch without it).
# Remote active-mode control, last-mode persistence, Game of Life injection.
KDESKDASH_REDIS_HOST=127.0.0.1
KDESKDASH_REDIS_PORT=6379
# Uncomment and set if your Redis requires a password (AUTH).
#REDISCLI_AUTH=changeme

# Telemetry source (optional) — kpidash publishes host metrics to a (typically
# remote) Redis. Read-only; a separate endpoint and auth from the control Redis.
# A down or slow source never affects boot or the control path.
KDESKDASH_TELEMETRY_REDIS_HOST=rpi53
KDESKDASH_TELEMETRY_REDIS_PORT=6379
# Uncomment and set if the telemetry Redis requires a password (AUTH).
#KDESKDASH_TELEMETRY_REDISCLI_AUTH=changeme
