[Unit]
Description=Redis claude-feed instance (kdeskdash, port 6380)
Documentation=https://github.com/kenhia/kdeskdash
After=network.target

[Service]
Type=notify
User=redis
Group=redis
ExecStart=/usr/bin/redis-server /etc/redis/redis-claude.conf --supervised systemd
Restart=always
RestartSec=3
StateDirectory=redis-claude
StateDirectoryMode=0750
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
